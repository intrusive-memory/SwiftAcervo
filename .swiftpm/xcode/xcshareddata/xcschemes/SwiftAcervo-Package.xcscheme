   <TestAction
      buildConfiguration = "Debug"
      selectedDebuggerIdentifier = "Xcode.DebuggerFoundation.Debugger.LLDB"
      selectedLauncherIdentifier = "Xcode.DebuggerFoundation.Launcher.LLDB"
      shouldUseLaunchSchemeArgsEnv = "NO">
      <!--
        ACERVO_APP_GROUP_ID supplies the App Group identifier to
        Acervo.sharedModelsDirectory. SwiftAcervo refuses to invent a
        per-process fallback path; tests use a dedicated bundle ID so they
        never write into a developer's real shared-models directory.
        Individual tests that need stricter isolation override this value
        per-test via the withIsolatedAcervoState helper.
      -->
      <EnvironmentVariables>
         <EnvironmentVariable
            key = "ACERVO_APP_GROUP_ID"
            value = "group.acervo.testbundle.default"
            isEnabled = "YES">
         </EnvironmentVariable>
      </EnvironmentVariables>
      <Testables>
         <TestableReference
            skipped = "NO">
            <BuildableReference
               BuildableIdentifier = "primary"
               BlueprintIdentifier = "SwiftAcervoTests"
               BuildableName = "SwiftAcervoTests"
               BlueprintName = "SwiftAcervoTests"
               ReferencedContainer = "container:">
            </BuildableReference>
         </TestableReference>
         <TestableReference
            skipped = "NO">
            <BuildableReference
               BuildableIdentifier = "primary"
               BlueprintIdentifier = "AcervoToolTests"
               BuildableName = "AcervoToolTests"
               BlueprintName = "AcervoToolTests"
               ReferencedContainer = "container:">
            </BuildableReference>
         </TestableReference>
      </Testables>
   </TestAction>
